APP_NAME=smart-article-recommender
APP_ENV=dev
API_PREFIX=/api/v1

POSTGRES_DB=content_db
POSTGRES_USER=content_user
POSTGRES_PASSWORD=content_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

DATABASE_URL=postgresql+asyncpg://content_user:content_pass@postgres:5432/content_db
DATABASE_SYNC_URL=postgresql+psycopg://content_user:content_pass@postgres:5432/content_db
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
MODEL_CACHE_DIR=/models/hf_cache
MODEL_DEVICE=cpu
MODEL_TOP_K_DEFAULT=5
MODEL_MAX_PROMPT_LENGTH=1200
MODEL_CONCURRENCY=2
MODEL_MAX_NEW_TOKENS=256

PROXY_PORT=80
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
